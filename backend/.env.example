DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=taskmanagement
SESSION_SECRET=change-me-to-a-long-random-string

# Send the session cookie only over HTTPS. Keep false for local HTTP
# (docker compose); set true only when TLS terminates in front of the app.
COOKIE_SECURE=false
